{
    "name": "stanley-crawler-event",
    "version": "0.0.0",
    "description": "Stanley TheTemplate for typescript project",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "homepage": "https://github.com/ODGodinho/Stanley-Crawler-Event",
    "repository": {
        "type": "git",
        "url": "https://github.com/ODGodinho/Stanley-Crawler-Event"
    },
    "imports": {
        "#types": "./@types/index.d.ts",
        "#app": "./src/app/index.ts",
        "#app/*": "./src/app/*",
        "#browser": "./src/Browser/index.ts",
        "#browser/*": "./src/Browser/*",
        "#configs": "./src/Configs/index.ts",
        "#configs/*": "./src/Configs/*",
        "#engine": "./src/engine.ts",
        "#enums": "./src/app/Enums/index.ts",
        "#enums/*": "./src/app/Enums/*",
        "#exceptions": "./src/Exceptions",
        "#exceptions/*": "./src/Exceptions/*",
        "#factory": "./src/app/Factory/index.ts",
        "#factory/*": "./src/app/Factory/*",
        "#handlers": "./src/Handlers/index.ts",
        "#handlers/*": "./src/Handlers/*",
        "#interfaces": "./src/Interfaces/index.ts",
        "#interfaces/*": "./src/Interfaces/*",
        "#listeners": "./src/app/Listeners/index.ts",
        "#listeners/*": "./src/app/Listeners/*",
        "#validator": "./src/Validator/index.ts",
        "#validator/*": "./src/Validator/*",
        "#pages": "./src/Pages/index.ts",
        "#pages/*": "./src/Pages/*",
        "#providers": "./src/app/Provider/index.ts",
        "#providers/*": "./src/app/Provider/*",
        "#selectors": "./src/Selectors/index.ts",
        "#selectors/*": "./src/Selectors/*",
        "#services": "./src/app/Services/index.ts",
        "#services/*": "./src/app/Services/*"
    },
    "scripts": {
        "build": "rimraf dist/ && tsc --project ./tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "build:watch": "concurrently 'bun run tsc:build -w' 'bun run tsc:alias -w'",
        "clean": "rimraf dist/ node_modules/ bun.lock*",
        "dev": "bun ./src/index.ts",
        "start": "bun ./dist/index.js",
        "reset": "bun run clean && bun install && bun run build",
        "lint": "odg-lint",
        "lint:fix": "odg-lint --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:ci": "vitest run --passWithNoTests",
        "test:watch": "vitest --watch",
        "tsc:check": "tsc --noEmit -p tsconfig.json",
        "tsc:build": "tsc --project ./tsconfig.build.json",
        "tsc:alias": "tsc-alias -p tsconfig.build.json"
    },
    "engines": {
        "node": ">=26.0.0",
        "bun": ">=1.3.14"
    },
    "publishConfig": {
        "access": "public"
    },
    "lint-staged": {
        "*": "bun run lint:fix"
    },
    "release": {
        "branches": [
            "+([0-9])?(.{+([0-9]),x}).x",
            "main",
            "master",
            "next",
            "next-major",
            {
                "name": "beta",
                "prerelease": true
            },
            {
                "name": "alpha",
                "prerelease": true
            }
        ],
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/npm",
            "@semantic-release/github"
        ]
    },
    "files": [
        "./dist/",
        "./@types/",
        "./README.md"
    ],
    "author": "Dragons Gamers <https://www.linkedin.com/in/victor-alves-odgodinho>",
    "license": "MIT",
    "devDependencies": {
        "@odg/command": "^1.22.0",
        "@odg/eslint-config": "^3.12.2",
        "@odg/tsconfig": "^1.7.0",
        "@types/node": "^26.1.0",
        "@vitest/coverage-istanbul": "^4.1.10",
        "bun-types": "^1.3.14",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "rimraf": "^6.1.3",
        "tsc-alias": "^1.9.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@inversifyjs/strongly-typed": "^3.0.0",
        "@odg/axios": "^1.24.0",
        "@odg/chemical-x": "^2.13.0",
        "@odg/config": "^1.11.0",
        "@odg/events": "^1.12.0",
        "@odg/exception": "^1.18.0",
        "@odg/json-log": "^1.16.0",
        "@odg/log": "^1.17.0",
        "@odg/message": "^1.24.0",
        "inversify": "^8.1.1",
        "playwright": "^1.61.1",
        "reflect-metadata": "^0.2.2",
        "zod": "^4.4.3"
    },
    "packageManager": "bun@1.3.14"
}
