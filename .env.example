# region [ rgba(0, 100, 255, 0.2) ]
# Application environment variables

# App name
APP_NAME="Stanley"

# Use Headless in browser
USE_HEADLESS=true

# BROWSER_CONNECT
BROWSER_CONNECT=""

# endregion

# region [ rgba(155, 89, 182, 0.15) ]
# Crawler Example

# Timeout of Handler to identify case
HANDLER_TIMEOUT=5000

# RetryTry Handler to identify case 5 * HANDLER_TIMEOUT = 10s Default
HANDLER_ATTEMPT=2

# Number of Attempt In page
PAGE_ATTEMPT=3

# endregion
